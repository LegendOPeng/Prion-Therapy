integrator  = md
nsteps      = 50000
dt          = 0.002
nstenergy   = 500
nstlog      = 500
nstxout-compressed = 500
cutoff-scheme = Verlet
coulombtype = PME
rcoulomb    = 1.0
rvdw        = 1.0
pbc         = xyz
tcoupl      = V-rescale
tc-grps     = Protein Non-Protein
tau_t       = 0.1 0.1
ref_t       = 310 310
pcoupl      = no
gen_vel     = yes
gen_temp    = 310
gen_seed    = -1
constraints = all-bonds
